---
import Layout from '../layouts/Layout.astro';
import ModuleCard from '../components/ModuleCard.astro';

// In Astro 4.x, BASE_URL does NOT include a trailing slash
// e.g. base: '/d439-oa-preparation' → BASE_URL = '/d439-oa-preparation'
const base = import.meta.env.BASE_URL;

const modules = [
  {
    title: 'D439 — Foundations of Nursing',
    description:
      'Interactive exam-review LMS covering all 21 units of the WGU D439 Foundations of Nursing course. Practice questions, inline rationales, progress tracking, and keyword search.',
    href: `${base}/d439/`,
    icon: '🏥',
    badge: 'Available',
  },
  {
    title: 'Nursing Pharmacology — Autonomic Drugs',
    description:
      'In-depth exam-review module covering cholinergics, anticholinergics, adrenergics, and antiadrenergics. Includes receptor pharmacology, drug prototypes, therapeutic uses, adverse effects, and challenging NCLEX-style practice questions.',
    href: `${base}/pharmacology/`,
    icon: '💊',
    badge: 'Available',
  },
  {
    title: 'Sleep — Nursing Exam Review',
    description:
      'Comprehensive exam-review module covering sleep physiology (NREM/REM), sleep disorders (insomnia, OSA, narcolepsy), CPAP therapy, and evidence-based nursing interventions for hospital sleep promotion. High-yield NCLEX-style practice questions with full rationales.',
    href: `${base}/sleep/`,
    icon: '😴',
    title: 'Wound Care Education',
    description:
      'Comprehensive wound care module covering wound healing fundamentals, pressure injury staging and prevention, wound assessment, dressing selection, débridement, and special wound types. Includes 15 practice questions with detailed rationales.',
    href: `${base}/wound-care/`,
    icon: '🩹',
    badge: 'Available',
  },
];
---

<Layout title="LMS Platform — Online Learning Modules">
  <div class="page-wrap">
    <header class="hero">
      <div class="hero-inner">
        <div class="hero-logo">🎓</div>
        <h1 class="hero-title">LMS Platform</h1>
        <p class="hero-subtitle">
          Select a course module below to begin studying. Progress is saved automatically in your browser.
        </p>
      </div>
    </header>

    <main class="main">
      <section class="modules-section">
        <h2 class="section-heading">Available Modules</h2>
        <div class="modules-grid">
          {modules.map((mod) => (
            <ModuleCard
              title={mod.title}
              description={mod.description}
              href={mod.href}
              icon={mod.icon}
              badge={mod.badge}
            />
          ))}
        </div>
      </section>

      <section class="coming-soon">
        <h2 class="section-heading">Coming Soon</h2>
        <div class="coming-grid">
          <div class="coming-card">
            <span class="coming-icon">📐</span>
            <span class="coming-label">Additional LMS modules will appear here as they are developed.</span>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <p>LMS Platform &mdash; Study smarter, not harder.</p>
    </footer>
  </div>
</Layout>

<style>
  .page-wrap {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ── */
  .hero {
    background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
    color: #fff;
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-logo {
    font-size: 3rem;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    opacity: 0.88;
    line-height: 1.6;
  }

  /* ── Main ── */
  .main {
    flex: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    width: 100%;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748B;
    margin-bottom: 1.25rem;
  }

  /* ── Modules Grid ── */
  .modules-section {
    margin-bottom: 3rem;
  }

  .modules-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Coming Soon ── */
  .coming-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .coming-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #fff;
    border: 1px dashed #CBD5E1;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    color: #94A3B8;
  }

  .coming-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .coming-label {
    font-size: 0.9rem;
  }

  /* ── Footer ── */
  .footer {
    border-top: 1px solid #E2E8F0;
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: #94A3B8;
  }

  @media (max-width: 600px) {
    .hero-title { font-size: 1.75rem; }
  }
</style>
